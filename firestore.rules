rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lessons collection - public read, authenticated write
    match /lessons/{lessonId} {
      allow read: if true; // Public read access for lesson content
      allow write: if request.auth != null; // Authenticated users can seed lessons
    }
    
    // Lesson progress - users can only access their own data
    match /lessonProgress/{progressId} {
      allow read, write: if request.auth != null && 
        (resource == null || request.auth.uid == resource.data.userId);
    }
    
    // User progress (legacy) - users can only access their own data
    match /userProgress/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isAdmin(request.auth.uid); // Admins can read all progress
    }
    
    // Users collection for profile data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isAdmin(request.auth.uid);
      allow create: if request.auth != null; // Allow user registration
    }
    
    // Admin helper function
    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
             get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}